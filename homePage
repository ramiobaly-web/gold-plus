        function applyGlobalTranslations() {
            const t = translations[userSettings.lang] || translations['en'];
            document.documentElement.dir = t.dir || 'ltr';
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (t[key]) { if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') el.placeholder = t[key]; else el.innerText = t[key]; }
            });
            document.querySelectorAll('.curr-sym').forEach(e => e.innerText = userSettings.currSymbol);
        }

        async function fetchGoldPrices() {
            const t = translations[userSettings.lang] || translations['ar'];
            const updateBtn = document.getElementById('update-btn');
            updateBtn.disabled = true; document.getElementById('last-update').innerText = t.updating || "Updating...";
            try {
                let response = await fetch("https://api.gold-api.com/price/XAU");
                let data = await response.json(); let liveOunceUsd = data.price;
                if(!liveOunceUsd || isNaN(liveOunceUsd)) throw new Error("Invalid Price");
                let rate = parseFloat(userSettings.currRate) || 3.75;
                
                // تحديث الستة بطاقات بالدولار والعملة المحلية
                document.getElementById('ounce-usd').innerText = liveOunceUsd.toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('ounce-local').innerText = Math.round(liveOunceUsd * rate).toLocaleString('en-US');
                document.getElementById('gram-usd').innerText = (liveOunceUsd / OUNCE_IN_GRAMS).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('gram-local').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * rate).toFixed(2);
                document.getElementById('kilo-usd').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * 1000).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('kilo-local').innerText = Math.round(((liveOunceUsd / OUNCE_IN_GRAMS) * 1000) * rate).toLocaleString('en-US');
                document.getElementById('tola-usd').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * TOLA_IN_GRAMS).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('tola-local').innerText = Math.round(((liveOunceUsd / OUNCE_IN_GRAMS) * TOLA_IN_GRAMS) * rate).toLocaleString('en-US');
                document.getElementById('q-kilo-usd').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * 250).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('q-kilo-local').innerText = Math.round(((liveOunceUsd / OUNCE_IN_GRAMS) * 250) * rate).toLocaleString('en-US');
                document.getElementById('h-kilo-usd').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * 500).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('h-kilo-local').innerText = Math.round(((liveOunceUsd / OUNCE_IN_GRAMS) * 500) * rate).toLocaleString('en-US');

                let now = new Date(); document.getElementById('last-update').innerText = (t.updated || "") + now.toLocaleTimeString(userSettings.lang === 'en' ? 'en-US' : 'ar-SA', {hour: '2-digit', minute:'2-digit'});
            } catch(e) { document.getElementById('last-update').innerText = t.failed || "Failed"; } finally { updateBtn.disabled = false; }
        }

        function handleCurrencyChange() {
            const select = document.getElementById('currency-select');
            if(select.value === 'CUSTOM') { document.getElementById('custom-curr-name-group').style.display = 'block'; document.getElementById('currency-rate').value = ''; } 
            else { document.getElementById('custom-curr-name-group').style.display = 'none'; document.getElementById('currency-rate').value = select.options[select.selectedIndex].getAttribute('data-rate'); }
        }
        function openSettings() { document.getElementById('lang-select').value = userSettings.lang; document.getElementById('currency-rate').value = userSettings.currRate; document.getElementById('settings-modal').style.display = 'flex'; }
        function closeSettings() { document.getElementById('settings-modal').style.display = 'none'; }
        function saveSettings() {
            const lang = document.getElementById('lang-select').value; const currSelect = document.getElementById('currency-select').value;
            let currSymbol = currSelect === 'CUSTOM' ? (document.getElementById('custom-curr-name').value || 'LOC') : currSelect;
            let currRate = parseFloat(document.getElementById('currency-rate').value);
            if(isNaN(currRate) || currRate <= 0) return alert("الرجاء إدخال قيمة صحيحة!");
            localStorage.setItem('gold_settings', JSON.stringify({ lang, currSymbol, currRate }));
            closeSettings(); location.reload();
        }
        // 1. دالة قراءة الثيم المحفوظ عند فتح الصفحة
        function applySavedTheme() {
            if (localStorage.getItem('gold_theme') === 'light') {
                document.body.classList.add('light-theme');
                const icon = document.getElementById('theme-icon');
                if(icon) icon.innerText = '☀️';
            }
        }

        // 2. دالة التبديل الجديدة (تحفظ الخيار في ذاكرة المتصفح)
        function toggleTheme() { 
            document.body.classList.toggle('light-theme'); 
            const isLight = document.body.classList.contains('light-theme');
            const icon = document.getElementById('theme-icon'); 
            if(icon) icon.innerText = isLight ? '☀️' : '🌙'; 
            localStorage.setItem('gold_theme', isLight ? 'light' : 'dark'); // هذا السطر هو الذي يحفظ الإعداد
        }

        window.onload = () => { applySavedTheme(); applyGlobalTranslations(); fetchGoldPrices(); };;
    </script>
</body>

</html>

