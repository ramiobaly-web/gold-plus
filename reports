        function applySavedTheme() {
            if (localStorage.getItem('gold_theme') === 'light') {
                document.body.classList.add('light-theme');
                const icon = document.getElementById('theme-icon');
                if(icon) icon.innerText = '☀️';
            }
        }

        function toggleTheme() { 
            document.body.classList.toggle('light-theme'); 
            const isLight = document.body.classList.contains('light-theme');
            const icon = document.getElementById('theme-icon'); 
            if(icon) icon.innerText = isLight ? '☀️' : '🌙'; 
            localStorage.setItem('gold_theme', isLight ? 'light' : 'dark');
        }

        function applyGlobalTranslations() {
            const t = translations[userSettings.lang] || translations['en'];
            document.documentElement.dir = t.dir || 'ltr';
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (t[key]) el.innerText = t[key];
            });
            document.querySelectorAll('.curr-sym').forEach(e => e.innerText = userSettings.currSymbol);
        }

        async function fetchGoldPrices() {
            const t = translations[userSettings.lang] || translations['ar'];
            const updateBtn = document.getElementById('update-btn');
            updateBtn.disabled = true; document.getElementById('last-update').innerText = t.updating || "Updating...";
            try {
                let response = await fetch("https://api.gold-api.com/price/XAU");
                let data = await response.json(); let liveOunceUsd = data.price;
                if(!liveOunceUsd || isNaN(liveOunceUsd)) throw new Error("Invalid");
                let rate = parseFloat(userSettings.currRate) || 3.75;
                let globalGramPriceLocal = (liveOunceUsd / OUNCE_IN_GRAMS) * rate;
                
                let gramUsd = liveOunceUsd / OUNCE_IN_GRAMS;
                
                document.getElementById('ounce-usd').innerText = liveOunceUsd.toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('ounce-local').innerText = Math.round(liveOunceUsd * rate).toLocaleString('en-US');
                document.getElementById('gram-usd').innerText = (liveOunceUsd / OUNCE_IN_GRAMS).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('gram-local').innerText = globalGramPriceLocal.toFixed(2);
                document.getElementById('kilo-usd').innerText = ((liveOunceUsd / OUNCE_IN_GRAMS) * 1000).toLocaleString('en-US', {minimumFractionDigits: 2});
                document.getElementById('kilo-local').innerText = Math.round(globalGramPriceLocal * 1000).toLocaleString('en-US');
                
                let now = new Date(); document.getElementById('last-update').innerText = (t.updated || "") + now.toLocaleTimeString(userSettings.lang === 'en' ? 'en-US' : 'ar-SA', {hour: '2-digit', minute:'2-digit'});
                
                generateReportsFromData(globalGramPriceLocal, userSettings.currSymbol); 
            } catch(e) { document.getElementById('last-update').innerText = t.failed || "Failed"; } finally { updateBtn.disabled = false; }
        }

        function generateReportsFromData(currentGramPriceLocal, sym) {
            const txs = JSON.parse(localStorage.getItem('gold_transactions')) || [];
            const cap = parseFloat(localStorage.getItem('gold_capital')) || 0;
            let rate = parseFloat(userSettings.currRate) || 3.75;

            let totalPurchases = 0; let totalSales = 0;
            let weightByKarat = { 24: 0, 22: 0, 21: 0, 18: 0 };
            let totalEq24kGrams = 0;  
            let totalCost = 0; let realizedProfit = 0;
            let matured24kGrams = 0; let immature24kGrams = 0; let closestDaysLeft = 354;

            const today = new Date();

            txs.forEach(tx => {
                let purity = parseInt(tx.purity) || 24;
                let weightInGrams = tx.weight;
                if(tx.unit === 'ounce') weightInGrams *= OUNCE_IN_GRAMS;
                else if(tx.unit === 'tola') weightInGrams *= TOLA_IN_GRAMS;
                else if(tx.unit === 'kilo') weightInGrams *= 1000;

                let eq24kWeight = weightInGrams * (purity / 24); 

                if(tx.type === 'buy') {
                    totalPurchases += tx.totalPrice; 
                    if(weightByKarat[purity] !== undefined) weightByKarat[purity] += weightInGrams;
                    totalEq24kGrams += eq24kWeight;
                    totalCost += tx.totalPrice;
                    
                    let txDate = new Date(tx.date); let diffDays = Math.floor((today - txDate) / (1000 * 60 * 60 * 24));
                    if (diffDays >= 354) { matured24kGrams += eq24kWeight; } 
                    else { immature24kGrams += eq24kWeight; let daysLeft = 354 - diffDays; if(daysLeft < closestDaysLeft) closestDaysLeft = daysLeft; }
                } else {
                    totalSales += tx.totalPrice; 
                    if(weightByKarat[purity] !== undefined) weightByKarat[purity] -= weightInGrams;
                    totalEq24kGrams -= eq24kWeight;
                    totalCost -= tx.originalPrice; 
                    realizedProfit += tx.profit;
                    
                    if (matured24kGrams >= eq24kWeight) { matured24kGrams -= eq24kWeight; } 
                    else { immature24kGrams -= (eq24kWeight - matured24kGrams); matured24kGrams = 0; }
                }
            });

            document.getElementById('w-24').innerText = weightByKarat[24].toFixed(2) + " g";
            document.getElementById('w-22').innerText = weightByKarat[22].toFixed(2) + " g";
            document.getElementById('w-21').innerText = weightByKarat[21].toFixed(2) + " g";
            document.getElementById('w-18').innerText = weightByKarat[18].toFixed(2) + " g";
            document.getElementById('rep-total-grams-eq').innerText = totalEq24kGrams.toFixed(2) + " g";

            const hawlElement = document.getElementById('hawl-time-left');
            if(immature24kGrams > 0) {
                let m = Math.floor(closestDaysLeft / 30); let d = closestDaysLeft % 30;
                let text = userSettings.lang === 'en' ? "Next due in: " : "أقرب دفعة تستحق بعد: ";
                if(m > 0) text += userSettings.lang === 'en' ? `${m} months ` : `${m} شهر `;
                if(d > 0) text += userSettings.lang === 'en' ? `and ${d} days` : `و ${d} يوم`;
                hawlElement.innerText = text; hawlElement.style.display = "block";
            } else { hawlElement.style.display = "none"; }

            const netCash = cap + totalSales - totalPurchases;
            const currentGoldValue = totalEq24kGrams * currentGramPriceLocal; 
            const unrealizedProfit = currentGoldValue - totalCost;

            // حساب متوسط سعر الشراء للجرام (محلي ودولار)
            let avgPricePerGramLocal = totalEq24kGrams > 0 ? (totalCost / totalEq24kGrams) : 0;
            let avgPricePerGramUsd = avgPricePerGramLocal / rate;

            // حساب متوسط سعر الشراء للأونصة (محلي ودولار)
            let avgPricePerOunceLocal = avgPricePerGramLocal * OUNCE_IN_GRAMS;
            let avgPricePerOunceUsd = avgPricePerGramUsd * OUNCE_IN_GRAMS;

            document.getElementById('rep-current-value').innerHTML = `${Math.round(currentGoldValue).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('rep-total-cost').innerHTML = `${Math.round(totalCost).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            
            // تحديث بطاقة الأونصة المزدوجة
            document.getElementById('rep-avg-ounce').innerHTML = `
                <span class="local-p">${avgPricePerOunceLocal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})} <span class="curr-sym">${sym}</span>/oz</span>
                <span class="usd-p">${avgPricePerOunceUsd.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})} $/oz</span>
            `;

            // تحديث بطاقة الجرام المزدوجة
            document.getElementById('rep-avg-gram').innerHTML = `
                <span class="local-p">${avgPricePerGramLocal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})} <span class="curr-sym">${sym}</span>/g</span>
                <span class="usd-p">${avgPricePerGramUsd.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})} $/g</span>
            `;
            
            document.getElementById('rep-realized-profit').innerHTML = `${realizedProfit >= 0 ? "+" : ""}${Math.round(realizedProfit).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            
            const profitEl = document.getElementById('rep-unrealized-profit');
            if(unrealizedProfit >= 0) { profitEl.innerHTML = `+ ${Math.round(unrealizedProfit).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`; profitEl.className = "val-green"; } 
            else { profitEl.innerHTML = `${Math.round(unrealizedProfit).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`; profitEl.className = ""; profitEl.style.color = "var(--sell-color)"; }

            document.getElementById('rep-capital').innerHTML = `${Math.round(cap).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('rep-purchases').innerHTML = `${Math.round(totalPurchases).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('rep-sales').innerHTML = `${Math.round(totalSales).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('rep-net-cash').innerHTML = `${Math.round(netCash).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;

            const maturedGoldValue = matured24kGrams * currentGramPriceLocal; 
            const immatureGoldValue = immature24kGrams * currentGramPriceLocal;
            const totalWealthGramsEq24k = totalEq24kGrams + (netCash / currentGramPriceLocal);
            
            let zakatBase = 0; let zakatAmount = 0;
            if (totalWealthGramsEq24k >= 85) { 
                zakatBase = maturedGoldValue + netCash; zakatAmount = zakatBase * 0.025;
                document.getElementById('zakat-status-badge').innerText = userSettings.lang === 'en' ? "Nisab Met" : "النصاب متجاوز"; document.getElementById('zakat-status-badge').className = "badge-green";
            } else {
                document.getElementById('zakat-status-badge').innerText = userSettings.lang === 'en' ? "Not Met" : "لم يبلغ النصاب"; document.getElementById('zakat-status-badge').className = "badge-gray";
            }

            document.getElementById('zakat-matured-grams').innerText = matured24kGrams.toFixed(2);
            document.getElementById('matured-gold-val').innerHTML = `${Math.round(maturedGoldValue).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('zakat-cash-val').innerHTML = `${Math.round(netCash).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('zakat-base-val').innerHTML = `${Math.round(zakatBase).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('zakat-immature-grams').innerText = immature24kGrams.toFixed(2);
            document.getElementById('immature-gold-val').innerHTML = `${Math.round(immatureGoldValue).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
            document.getElementById('zakat-amount').innerHTML = `${Math.round(zakatAmount).toLocaleString('en-US')} <span class="curr-sym">${sym}</span>`;
        }

        window.onload = () => { applySavedTheme(); applyGlobalTranslations(); fetchGoldPrices(); };
    </script>
</body>
</html>
