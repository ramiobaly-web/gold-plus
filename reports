        body.light-theme { --bg-color: #F5F7FA; --card-bg: #FFFFFF; --gold-accent: #B8860B; --text-main: #121212; --text-sub: #555555; --nav-bg: #FFFFFF; --border-color: #E5E5E5; --buy-color: #388E3C; --sell-color: #D32F2F; --zakat-bg: rgba(184, 134, 11, 0.05); }
