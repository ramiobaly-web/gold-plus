        .bottom-nav { position: fixed; bottom: 0; right: 0; width: 100%; background-color: var(--nav-bg); border-top: 1px solid var(--border-color); display: flex; justify-content: space-around; padding: 10px 0; z-index: 100; } .nav-item { text-align: center; color: var(--text-sub); font-size: 11px; cursor: pointer; font-weight: 600; display: flex; flex-direction: column; align-items: center; gap: 3px; text-decoration: none;} .nav-item.active { color: var(--gold-accent); } .nav-icon { font-size: 18px; display: block;}
