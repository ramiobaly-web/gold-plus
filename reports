<body>
    <div class="container">
        <div class="top-bar"><div class="app-title" data-i18n="rep_title">التقارير 📊</div><button class="icon-btn" onclick="toggleTheme()" id="theme-icon">🌙</button></div>
        
        <div class="prices-header">
            <div class="update-bar"><div class="time-stamp" id="last-update" data-i18n="updating">جاري التحديث...</div><button class="update-btn" id="update-btn" onclick="fetchGoldPrices()" data-i18n="update_btn">تحديث السعر</button></div>
            <div class="mini-dashboard-grid">
                <div class="mini-price-card">
                    <h3 data-i18n="ounce">الأونصة</h3>
                    <p class="mini-local-price"><span id="ounce-local">0</span> <span class="curr-sym">SAR</span></p>
                    <p class="mini-usd-price"><span id="ounce-usd">0</span> $</p>
                </div>
                <div class="mini-price-card">
                    <h3 data-i18n="gram24">الجرام (24)</h3>
                    <p class="mini-local-price"><span id="gram-local">0</span> <span class="curr-sym">SAR</span></p>
                    <p class="mini-usd-price"><span id="gram-usd">0</span> $</p>
                </div>
                <div class="mini-price-card">
                    <h3 data-i18n="kilo">الكيلو</h3>
                    <p class="mini-local-price"><span id="kilo-local">0</span> <span class="curr-sym">SAR</span></p>
                    <p class="mini-usd-price"><span id="kilo-usd">0</span> $</p>
                </div>
            </div>
        </div>

        <div class="section-title" data-i18n="gold_analysis">تحليل الذهب</div>
        <div class="report-grid">
            <div class="report-card full" style="align-items: stretch; text-align: start;">
                <h4 data-i18n="weight_breakdown" style="text-align: center; font-size: 14px; color: var(--gold-accent);">تفصيل الأوزان حسب العيار</h4>
                <div class="weight-breakdown">
                    <div class="weight-row"><span data-i18n="k24_weight">ذهب عيار 24 (سبائك):</span> <span class="w-val" id="w-24">0.00 g</span></div>
                    <div class="weight-row"><span data-i18n="k22_weight">ذهب عيار 22 (جنيهات إنجليزية):</span> <span class="w-val" id="w-22">0.00 g</span></div>
                    <div class="weight-row"><span data-i18n="k21_weight">ذهب عيار 21 (جنيهات رشادية/زينة):</span> <span class="w-val" id="w-21">0.00 g</span></div>
                    <div class="weight-row"><span data-i18n="k18_weight">ذهب عيار 18:</span> <span class="w-val" id="w-18">0.00 g</span></div>
                    <div class="weight-row total-eq">
                        <span data-i18n="total_eq_24k">المجموع المساوي لعيار 24 قيراط:</span> <span class="w-val" id="rep-total-grams-eq">0.00 g</span>
                    </div>
                </div>
            </div>
            
            <div class="report-card full"><h4 data-i18n="current_gold_value">سعر الذهب الموجود (بالسعر الحالي)</h4><p id="rep-current-value" class="val-gold">0 <span class="curr-sym">SAR</span></p></div>
            <div class="report-card full"><h4 data-i18n="sum_cost">تكلفة الذهب المتوفر</h4><p id="rep-total-cost">0 <span class="curr-sym">SAR</span></p></div>
            
            <div class="report-card">
                <h4 data-i18n="sum_avg_ounce">متوسط سعر الشراء للأونصة (24K)</h4>
                <div class="dual-price" id="rep-avg-ounce">
                    <span class="local-p">0 <span class="curr-sym">SAR</span>/oz</span>
                    <span class="usd-p">0 $/oz</span>
                </div>
            </div>
            
            <div class="report-card">
                <h4 data-i18n="sum_avg_gram">متوسط سعر الشراء للجرام (24K)</h4>
                <div class="dual-price" id="rep-avg-gram">
                    <span class="local-p">0 <span class="curr-sym">SAR</span>/g</span>
                    <span class="usd-p">0 $/g</span>
                </div>
            </div>

            <div class="report-card"><h4 data-i18n="sum_realized">الأرباح المحققة (مباع)</h4><p class="val-green" id="rep-realized-profit">0 <span class="curr-sym">SAR</span></p></div>
            <div class="report-card"><h4 data-i18n="sum_unrealized">الربح غير المحقق</h4><p class="val-green" id="rep-unrealized-profit">0 <span class="curr-sym">SAR</span></p></div>
        </div>

        <div class="section-title" data-i18n="zakat_title">محرك الزكاة التلقائي</div>
        <div class="zakat-card">
            <div class="zakat-header"><span class="zakat-icon">🌙</span><div class="zakat-title-box"><h3 data-i18n="zakat_hawl">متابعة الحول والنصاب</h3><p data-i18n="zakat_desc">يتم حساب 2.5% فقط على الأصول التي أتمت سنة هجرية.</p></div></div>
            <div class="zakat-section" style="border-left: 3px solid #4CAF50;">
                <div class="z-sec-title"><span data-i18n="assets_matured">أصول حال عليها الحول</span> <span class="badge-green" id="zakat-status-badge">مستحق</span></div>
                <div class="z-row"><span><span data-i18n="gold_matured">الذهب المستحق</span> (<span id="zakat-matured-grams">0</span>g <span data-i18n="k24_pure">24K</span>):</span> <strong id="matured-gold-val">0 <span class="curr-sym">SAR</span></strong></div>
                <div class="z-row"><span data-i18n="available_cash_note">الكاش المتوفر (في حال أتم عاماً هجرياً كاملاً):</span> <strong id="zakat-cash-val">0 <span class="curr-sym">SAR</span></strong></div>
                <div class="z-row" style="margin-top: 5px; border-top: 1px dashed var(--border-color); padding-top: 5px;"><span data-i18n="zakat_base">الوعاء الزكوي الخاضع:</span> <strong id="zakat-base-val">0 <span class="curr-sym">SAR</span></strong></div>
            </div>
            <div class="zakat-section">
                <div class="z-sec-title"><span data-i18n="assets_immature">ذهب لم يحل عليه الحول</span> <span class="badge-gray" data-i18n="not_due">غير مستحق</span></div>
                <div class="z-row"><span><span data-i18n="gold_rem">الذهب المتبقي</span> (<span id="zakat-immature-grams">0</span>g <span data-i18n="k24_pure">24K</span>):</span> <strong id="immature-gold-val">0 <span class="curr-sym">SAR</span></strong></div>
                <div class="hawl-text" id="hawl-time-left">لا يوجد ذهب غير مستحق</div>
            </div>
            <div class="zakat-final-amount"><h4 data-i18n="zakat_due_now">الزكاة المستحقة الدفع (2.5%)</h4><div class="amount" id="zakat-amount">0 <span class="curr-sym">SAR</span></div></div>
            <p style="font-size: 10px; color: var(--text-sub); margin-top: 15px; text-align: center; border-top: 1px dashed var(--border-color); padding-top: 10px;" data-i18n="zakat_note">ملاحظة: حاسبة الزكاة لتسهيل الحساب ويتوجب على الشخص مراجعة أصوله والاستحقاق بالطرق المناسبة. (يتم تحويل الأوزان المعروضة هنا لمعادل عيار 24 لضمان دقة النصاب).</p>
        </div>

        <div class="section-title" data-i18n="cash_flow">حركة الصندوق</div>
        <div class="report-grid" style="margin-bottom: 25px;">
            <div class="report-card full"><h4 data-i18n="invest_amount">مبلغ الاستثمار الكامل</h4><p class="val-gold" id="rep-capital">0 <span class="curr-sym">SAR</span></p></div>
            <div class="report-card" style="border-left: 3px solid var(--sell-color);"><h4 data-i18n="purchases">مجموع الشراء</h4><p id="rep-purchases">0 <span class="curr-sym">SAR</span></p></div>
            <div class="report-card" style="border-left: 3px solid var(--buy-color);"><h4 data-i18n="sales">مجموع البيع</h4><p id="rep-sales">0 <span class="curr-sym">SAR</span></p></div>
            <div class="report-card full" style="background-color: rgba(212, 175, 55, 0.05);"><h4 data-i18n="net_cash">الكاش المتوفر</h4><p class="val-gold" id="rep-net-cash">0 <span class="curr-sym">SAR</span></p></div>
        </div>
    </div>

