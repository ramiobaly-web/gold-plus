        .report-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; } .report-card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; text-align: center; display: flex; flex-direction: column; justify-content: center;} .report-card.full { grid-column: span 2; } .report-card h4 { margin: 0 0 5px 0; font-size: 11px; color: var(--text-sub); } .report-card p { margin: 0; font-size: 16px; font-weight: 700; color: var(--text-main); direction: ltr;} .val-green { color: var(--buy-color) !important; } .val-gold { color: var(--gold-accent) !important; font-size: 20px !important;}
        
        .weight-breakdown { font-size: 13px; text-align: right; margin-top: 10px; direction: rtl;}
        body[dir="ltr"] .weight-breakdown { text-align: left; direction: ltr; }
        .weight-row { display: flex; justify-content: space-between; border-bottom: 1px dashed var(--border-color); padding: 4px 0; color: var(--text-sub);}
